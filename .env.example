# Optional: turn on real cloud accounts + cross-device sync (Supabase).
# Copy this file to ".env.local" and paste in your project's two values from
# the Supabase dashboard → Project Settings → API. Leave it unset to keep Pulse
# fully local (on-device accounts).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
