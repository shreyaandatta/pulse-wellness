# Copy this file to ".env.local" and fill in what you need. Leave a section blank
# to keep that feature off — Pulse runs fine without any of these.

# ── Cloud accounts + cross-device sync (Supabase) ───────────────────────────
# From Supabase dashboard → Project Settings → API. The anon key is public-safe.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Pulse Plus payments (Razorpay) ──────────────────────────────────────────
# Requires Supabase above (Plus is tied to a cloud account).
#
# CLIENT (safe to expose — shipped in the browser bundle):
VITE_RAZORPAY_KEY_ID=

# SERVER ONLY (used by the /api functions — NEVER prefix these with VITE_, never
# commit them; add them in Vercel → Settings → Environment Variables):
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_MONTHLY=
RAZORPAY_PLAN_YEARLY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Ads (Google AdSense) ────────────────────────────────────────────────────
# Free plan only — Plus removes ads. Both values come from your APPROVED AdSense
# account and are public-safe (shipped in the browser bundle). Leave blank to
# keep ads off entirely (no script, no slots, no consent banner).
#   CLIENT: your publisher id, e.g. ca-pub-1234567890123456
#   SLOT:   an ad unit's slot id from AdSense → Ads → By ad unit (digits only)
# Also: put your real google.com line in public/ads.txt once approved.
VITE_ADSENSE_CLIENT=
VITE_ADSENSE_SLOT=
